# ===========================================
# DJANGO SETTINGS - PRODUCTION READY
# ===========================================

# SECURITY: Generate a strong secret key
# You can generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-and-secure-secret-key-here

# SECURITY: Set to False in production
DEBUG=False

# SECURITY: Configure allowed hosts for your domain
# For production: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-server-ip
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,yourdomain.com,www.yourdomain.com

# ===========================================
# DATABASE CONFIGURATION - DOCKER READY
# ===========================================

# PostgreSQL Database Configuration
# IMPORTANT: Change these credentials for security!
DB_NAME=chip_broker_db
DB_USER=chip_user
DB_PASSWORD=your-very-secure-database-password-here
# For Docker: DB_HOST=db (container name)
# For local development: DB_HOST=localhost
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=prefer

# ===========================================
# EMAIL CONFIGURATION
# ===========================================

# For development (logs to console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# SECURITY & PERFORMANCE SETTINGS
# ===========================================

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW=300

# ===========================================
# DOCKER & DEPLOYMENT SETTINGS
# ===========================================

# Static and Media Files (handled by Docker volumes)
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://redis:6379/0

# ===========================================
# PRODUCTION SECURITY SETTINGS
# ===========================================

# HTTPS Settings (enable in production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Sentry DSN for error monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
